# -----------------------------------------------------------------------------
# Environment variables for the automation framework.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# -----------------------------------------------------------------------------

# Target environment: dev | stage | prod (selects config/<env>.yaml)
APP_ENV=dev

# When true, secrets are fetched from Azure Key Vault via DefaultAzureCredential.
# When false, the framework reads secret values directly from this .env file.
USE_KEYVAULT=false

# Azure Key Vault (only required when USE_KEYVAULT=true)
KEYVAULT_NAME=

# -----------------------------------------------------------------------------
# Direct secret values (used when USE_KEYVAULT=false). Names match the Key Vault
# secret names with `<env>-` prefix stripped.
# -----------------------------------------------------------------------------
API_KEY=demo-api-key-123
OAUTH_CLIENT_ID=demo-client
OAUTH_CLIENT_SECRET=demo-secret-789
BASIC_AUTH_USERNAME=demo
BASIC_AUTH_PASSWORD=password123
